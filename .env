import os

def get_env(name):
    value = os.getenv(name)
    if not value:
        raise Exception(f"Missing ENV: {name}")
    return value

API_ID = int(get_env("API_ID"))
API_HASH = get_env("API_HASH")
BOT_TOKEN = get_env("BOT_TOKEN")

MONGO_URL = get_env("MONGO_URL")

OWNER_ID = int(get_env("OWNER_ID"))
ADMINS = list(map(int, get_env("ADMINS").split(",")))

FORCE_CHANNEL = get_env("FORCE_CHANNEL")
